# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_style = space
indent_size = 4
tab_width = 4

[*.{yml,yaml,json,jsx,js,css,html,md}]
indent_style = space
indent_size = 2
tab_width = 2

# Markdown: keep trailing whitespace (two trailing spaces = hard line break)
# and don't force a final newline.
[*.md]
trim_trailing_whitespace = false
insert_final_newline = false
