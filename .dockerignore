# Virtual environment and cache
.venv/
__pycache__/
*.pyc
*.pyo

# Git
.git/
.gitignore

# Node modules (web/dist is included; node_modules is not needed)
web/node_modules/

# IDE / editor
.vscode/
.VSCodeCounter/
*.code-workspace

# Docker artifacts (avoid recursive COPY)
Dockerfile
docker-compose.yml
docker-entrypoint.sh
.dockerignore

# Dev / docs / tooling (not needed at runtime)
docs/
build/
tests/
scripts/
examples/
agent/
*.md

# PyInstaller output
dist/
